# Zero-secret demo path - no values required.
INTELLIGENCE_HUB_DB=data/demo/intelligence_hub_demo.sqlite
INTELLIGENCE_HUB_FIXTURE_ROOT=data/fixtures
INTELLIGENCE_HUB_GITHUB_WATCHLIST_FILE=data/watchlists/github_repos.json
INTELLIGENCE_HUB_PAPER_WATCHLIST_FILE=data/watchlists/papers.json
INTELLIGENCE_HUB_DOMAIN_WATCHLIST_FILE=data/watchlists/domain_signals.json
INTELLIGENCE_HUB_SYNTHESIS_MODE=off

# Compatibility aliases still supported by legacy Hermes entrypoints.
HERMES_MODEL_PROVIDER=cloud
HERMES_RESEARCH_TOPIC=local-first AI engineering workflows
HERMES_SOURCE_FILE=data/sources/ai_research_items.json
HERMES_MEMORY_DB=data/hermes_memory.sqlite
HERMES_GITHUB_WATCHLIST_FILE=data/watchlists/github_repos.json
HERMES_PAPER_WATCHLIST_FILE=data/watchlists/papers.json
HERMES_DOMAIN_WATCHLIST_FILE=data/watchlists/domain_signals.json
HERMES_FIXTURE_ROOT=data/fixtures

# Optional - Cloud LLM.
# Use any OpenAI-compatible /v1/chat/completions endpoint.
# Production go-live expects FAST and PRO to be different models for token-cost control.
HERMES_CLOUD_BASE_URL=https://api.openai.com/v1
HERMES_CLOUD_API_KEY=
HERMES_FAST_MODEL=
HERMES_PRO_MODEL=
HERMES_CLOUD_TIMEOUT_SECONDS=60
HERMES_SYNTHESIS_MODE=hybrid
HERMES_PRO_CALL_LIMIT=8

# Optional - local fallback provider.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Optional - integrations.
# GitHub live fetching.
GITHUB_TOKEN=
GH_TOKEN=

# Notion publishing.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DAILY_BRIEFS_DATABASE_ID=
NOTION_PAPERS_DATABASE_ID=
NOTION_GITHUB_REPOS_DATABASE_ID=
NOTION_ECOSYSTEM_DATABASE_ID=
NOTION_DECISIONS_DATABASE_ID=
NOTION_RADAR_SNAPSHOTS_DATABASE_ID=
NOTION_RADAR_ENTITIES_DATABASE_ID=

# Obsidian publishing outside the fixture demo path.
INTELLIGENCE_HUB_OBSIDIAN_ENABLED=false
INTELLIGENCE_HUB_OBSIDIAN_VAULT_PATH=
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT_PATH=

# Telegram notification.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOKEN=
TG_BOT_TOKEN=
TG_CHAT_ID=

# Planned - semantic interest filtering is not wired into the pipeline yet.
# HERMES_INTEREST_PROFILE=
# HERMES_RELEVANCE_THRESHOLD=7
